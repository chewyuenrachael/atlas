# =============================================================================
# Cursor Community Atlas — environment variables
# =============================================================================
# Copy this file to `.env` (root) or `.env.local` (apps/cockpit) and fill in
# values. NEVER commit a real `.env` file. Secrets management is via the
# hosting provider (Vercel, Supabase, Inngest dashboards) in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Postgres + Auth + pgvector). See SPEC.md §2.3.
# -----------------------------------------------------------------------------
# Project URL, copy from Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Anonymous key, safe to expose to the browser (RLS enforces access).
SUPABASE_ANON_KEY=your-anon-key
# Service role key, server-only. Bypasses RLS. Treat as secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection URL for migrations and admin scripts.
DATABASE_URL=postgresql://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Inngest (workflow engine). See SPEC.md §2.3 / §5.3.
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=signkey-prod-your-signing-key
# Optional: local dev URL.
INNGEST_DEV_URL=http://localhost:8288

# -----------------------------------------------------------------------------
# LLM providers. See SPEC.md §2.3.
# -----------------------------------------------------------------------------
# Anthropic Claude API (primary LLM for Ask Anything, classification, drafting).
ANTHROPIC_API_KEY=sk-ant-your-key
# OpenAI (used for embeddings, text-embedding-3-small by default).
OPENAI_API_KEY=sk-your-openai-key

# -----------------------------------------------------------------------------
# Source adapters. See SPEC.md §5.2.
# -----------------------------------------------------------------------------
# Luma — events + attendee data (lu.ma).
LUMA_API_KEY=your-luma-api-key
LUMA_COMMUNITY_SLUG=cursorcommunity

# GitHub — personal access token with read:user, public_repo scopes.
GITHUB_TOKEN=ghp_your-token

# Twitter / X — bearer token (or use scraping fallback).
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Reddit — OAuth2 app credentials.
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=atlas:cursor-community-atlas:v0.1 (by /u/your-username)

# YouTube Data API v3 — key with YouTube Data API enabled.
YOUTUBE_API_KEY=your-youtube-key

# Hacker News uses the Algolia search API — no auth required.

# LinkedIn (Phase 3+) — Phantombuster or Bright Data credentials.
LINKEDIN_SCRAPER_API_KEY=your-scraper-key

# Cursor Forum scraper base URL (Phase 2).
CURSOR_FORUM_BASE_URL=https://forum.cursor.com

# -----------------------------------------------------------------------------
# Frontend (Mapbox, Next.js). Variables exposed to the browser must be prefixed
# with `NEXT_PUBLIC_`. See SPEC.md §2.3.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Observability. See SPEC.md §9.
# -----------------------------------------------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
# Service name surfaced in structured logs.
SERVICE_NAME=atlas
# Deployment environment tag.
ATLAS_ENV=development
