{
  "name": "@atlas/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Supabase / Postgres client wrapper and named query helpers. All SQL access flows through this package.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./queries": "./src/queries/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@supabase/supabase-js": "^2.45.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
