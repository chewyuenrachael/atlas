{
  "name": "@atlas/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared types, constants, errors, Result helpers, and logger for the Atlas.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./constants": "./src/constants.ts",
    "./errors": "./src/errors.ts",
    "./result": "./src/result.ts",
    "./logger": "./src/logger.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
