{
  "name": "@atlas/adapter-github",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub source adapter for the Cursor Community Atlas. See SPEC.md §5.2.2.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@atlas/adapters-shared": "workspace:*",
    "@octokit/rest": "^21.0.2"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
