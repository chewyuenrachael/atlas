{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Cursor Community Atlas — keystone data layer for the Cursor community function. See SPEC.md.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @atlas/cockpit dev",
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm --filter @atlas/cockpit build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.11",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
