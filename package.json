{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Cursor Community Atlas — keystone data layer for the Cursor community function. See SPEC.md.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @atlas/cockpit dev",
    "build": "pnpm -r --filter \"./packages/**\" build && pnpm --filter @atlas/cockpit build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "node --env-file=.env --import tsx packages/db/src/migrate.ts",
    "db:rollback": "node --env-file=.env --import tsx packages/db/src/rollback.ts",
    "db:smoke": "RUN_SMOKE_TESTS=1 node --env-file=.env node_modules/vitest/vitest.mjs run packages/db/src/__tests__/smoke.test.ts",
    "backfill:luma": "node --env-file=.env --import tsx scripts/backfill-luma.ts",
    "backfill:hackernews": "node --env-file=.env --import tsx scripts/backfill-hackernews.ts",
    "backfill:reddit": "node --env-file=.env --import tsx scripts/backfill-reddit.ts",
    "backfill:github": "node --env-file=.env --import tsx scripts/backfill-github.ts",
    "backfill:all": "node --env-file=.env --import tsx scripts/backfill-all.ts",
    "verify:phase-1": "node --env-file=.env --import tsx scripts/verify-phase-1.ts",
    "verify:phase-2": "node --env-file=.env --import tsx scripts/verify-phase-2.ts",
    "reconcile:cross-platform": "node --env-file=.env --import tsx scripts/reconcile-cross-platform.ts",
    "discover:findings": "node --env-file=.env --import tsx scripts/discover-findings.ts",
    "refresh:views": "node --env-file=.env --import tsx scripts/refresh-views.ts"
  },
  "devDependencies": {
    "@atlas/adapter-luma": "workspace:*",
    "@atlas/adapter-hackernews": "workspace:*",
    "@atlas/adapter-reddit": "workspace:*",
    "@atlas/adapter-github": "workspace:*",
    "@atlas/core": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/intelligence-identity-resolution": "workspace:*",
    "@atlas/workflows-shared": "workspace:*",
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.16.11",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^1.6.0"
  }
}
